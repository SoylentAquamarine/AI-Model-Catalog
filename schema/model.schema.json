{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soylentaquamarine.github.io/AI-Model-Catalog/schema/model.schema.json",
  "title": "AI Model Catalog Model Offering",
  "type": "object",
  "required": ["id", "providerId", "cost", "capabilities", "source"],
  "properties": {
    "id": { "type": "string" },
    "providerId": { "type": "string" },
    "providerModelId": { "type": "string" },
    "displayName": { "type": "string" },
    "baseModelRef": { "type": ["string", "null"] },
    "status": { "enum": ["active", "deprecated", "preview", "experimental", "unknown"] },
    "cost": {
      "type": "object",
      "required": ["class"],
      "properties": {
        "class": { "enum": ["free", "paid", "trial", "local", "unknown"] },
        "inputPerMillion": { "type": ["number", "null"] },
        "outputPerMillion": { "type": ["number", "null"] },
        "currency": { "type": "string", "default": "USD" }
      },
      "additionalProperties": true
    },
    "limits": {
      "type": "object",
      "properties": {
        "contextTokens": { "type": ["integer", "null"] },
        "maxOutputTokens": { "type": ["integer", "null"] }
      },
      "additionalProperties": true
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["value", "source", "confidence"],
        "properties": {
          "value": { "enum": [true, false, "unknown", "likely", "partial"] },
          "source": { "type": "string" },
          "confidence": { "enum": ["high", "medium", "low", "unknown"] },
          "lastChecked": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "source": {
      "type": "object",
      "required": ["type", "confidence"],
      "properties": {
        "type": { "type": "string" },
        "name": { "type": ["string", "null"] },
        "url": { "type": ["string", "null"] },
        "lastChecked": { "type": ["string", "null"] },
        "confidence": { "enum": ["high", "medium", "low", "unknown"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
